{
  "data_source": {
    "provider": "tushare",
    "tushare_token": "your-tushare-token"
  },
  "database": {
    "type": "mysql",
    "host": "localhost",
    "port": 3306,
    "user": "root",
    "password": "",
    "db": "db_daily_strategy"
  },
  "api": {
    "provider": "gemini-openai"
  },
  "api_gemini-openai": {
    "provider": "gemini-openai",
    "api_key": "your-api-key",
    "base_url": "",
    "model": "gemini-3-pro-high"
  },
  "api_vertex_gemini": {
    "provider": "gemini",
    "credentials_path": "",
    "project_id": "",
    "location": "",
    "model": "gemini-2.5-flash"
  },
  "api_glm": {
    "provider": "glm",
    "api_key": "",
    "base_url": "https://open.bigmodel.cn/api/coding/paas/v4",
    "model": "glm-4.7"
  },
  "api_deepseek": {
    "provider": "deepseek",
    "api_key": "",
    "base_url": "https://api.lkeap.cloud.tencent.com/v1",
    "model": "deepseek-v3.1"
  },
  "analysis": {
    "lookback_days": 365,
    "ma_short": 20,
    "ma_long": 60
  },
  "selection_rules": {
    "enabled": true,
    "min_change": 2.0,
    "max_change": 8.0,
    "min_volume_ratio": 1.5,
    "min_turnover": 3.0,
    "max_turnover": 15.0,
    "min_mcap_b": 30,
    "max_mcap_b": 1000,
    "exclude_loss_making": true,
    "exclude_startup_board": true,
    "exclude_star_market": true,
    "max_candidates_rough": 100,
    "min_score": 70,
    "max_final_candidates": 5
  }
}